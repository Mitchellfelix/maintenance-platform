DATABASE_URL="postgresql://maintenance:maintenance@localhost:5432/maintenance_platform"
JWT_SECRET="change-me-in-production"
CORS_ORIGIN="http://localhost:5173"
PORT=3000
NODE_ENV=development
HOST="0.0.0.0"

# Team mode: shared URL for all desktop clients (set via npm run team:connect -- <url>).
# When set to a non-localhost URL, emat skips local Docker/Postgres and opens this address.
# Also used as the review link base in access-request emails / Slack messages.
# EMAT_APP_URL="http://192.168.1.50:3000"
# EMAT_APP_URL="https://emat.yourcompany.internal"
# APP_URL="http://192.168.1.50:3000"

# --- Railway (production) ---
# See docs/RAILWAY.md. Typical web-service variables:
# DATABASE_URL=          (from Railway Postgres plugin)
# JWT_SECRET=            (strong random)
# EMAT_APP_URL=https://YOUR-APP.up.railway.app
# APP_URL=https://YOUR-APP.up.railway.app
# CORS_ORIGIN=true
# EMAT_DATA_DIR=/data
# HOST=0.0.0.0
# Optional path overrides (defaults derived from EMAT_DATA_DIR):
# UPLOAD_ROOT=/data/uploads
# EMAT_DOWNLOADS_DIR=/data/downloads

# --- Email / Slack notifications (optional) ---
# Prefer Resend if both Resend and SMTP are set.
#
# Emails when configured:
# - New access requests → ACTIVE ADMIN + OPS_LEAD
# - Access request approved → the requester
# - Admin creates a user → welcome email with temporary password
# - Invite accepted → confirmation that the account is ready
# - Forgot password → one-time reset link (30 minutes)
# Slack (if set) only for new access requests.

# Resend (https://resend.com) — easiest for app email
# RESEND_API_KEY="re_xxxxxxxx"
# MAIL_FROM="EMAT <notifications@yourcompany.com>"

# Or SMTP (company mail / Google Workspace / Outlook)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER="emat@yourcompany.com"
# SMTP_PASS="app-password"
# MAIL_FROM="EMAT <emat@yourcompany.com>"

# Slack Incoming Webhook (channel notifications)
# Create at: https://api.slack.com/apps → Incoming Webhooks
# SLACK_WEBHOOK_URL="https://hooks.slack.com/services/XXX/YYY/ZZZ"
