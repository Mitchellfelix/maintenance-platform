// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ——— Enums ———

enum UserRole {
  ADMIN
  OPS_LEAD
  OPERATOR
  REQUESTER
}

enum UserStatus {
  PENDING
  ACTIVE
}

enum WorkOrderStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AssetOperationalStatus {
  OPERATIONAL
  DEGRADED
  OFFLINE
  DECOMMISSIONED
}

enum AccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum GreenTagStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

// ——— Auth & people ———

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      UserRole   @default(REQUESTER)
  status    UserStatus @default(PENDING)
  createdAt DateTime   @default(now())
  updatedAt DateTime @updatedAt

  workOrdersRequested WorkOrder[]     @relation("WorkOrderRequester")
  workOrdersAssigned  WorkOrder[]     @relation("WorkOrderAssignee")
  workOrderNotes      WorkOrderNote[]
  timeEntries         WorkOrderTimeEntry[]
  siteAccess          SiteAccess[]
  auditLogs           AuditLog[]      @relation("AuditActor")
  accessRequests      AccessRequest[] @relation("AccessRequestRequester")
  accessReviews       AccessRequest[] @relation("AccessRequestReviewer")
  sopVersionsPublished SopVersion[]   @relation("SopVersionPublisher")
  invitesSent         UserInvite[]    @relation("InviteSender")
  passwordResets      PasswordReset[]
  greenTagAssignments GreenTagAssignment[] @relation("GreenTagAssignee")
  greenTagChecklistCompletions GreenTagChecklistItem[] @relation("GreenTagChecklistCompleter")
  greenTagChecklistPhotos GreenTagChecklistPhoto[] @relation("GreenTagChecklistPhotoUploader")
}

// ——— Locations & equipment ———

model Site {
  id        String   @id @default(cuid())
  name      String
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets     Asset[]
  workOrders WorkOrder[]
  siteAccess SiteAccess[]
}

model Asset {
  id                  String                   @id @default(cuid())
  siteId              String
  site                Site                     @relation(fields: [siteId], references: [id], onDelete: Restrict)
  name                String
  description         String?
  serialNumber        String?                  @unique
  operationalStatus   AssetOperationalStatus   @default(OPERATIONAL)
  installedAt         DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  workOrders WorkOrder[]
  inventoryParts InventoryPart[]
  greenTagAssignments GreenTagAssignment[]

  @@index([siteId])
  @@index([operationalStatus])
}

// ——— Work management ———

model WorkOrder {
  id          String            @id @default(cuid())
  /// Human-facing reference (e.g. WO-2026-00042). Set in application logic.
  code        String            @unique
  title       String
  description String?
  status      WorkOrderStatus   @default(OPEN)
  priority    WorkOrderPriority @default(MEDIUM)

  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Restrict)

  assetId String?
  asset   Asset?  @relation(fields: [assetId], references: [id], onDelete: SetNull)

  requesterId String
  requester   User   @relation("WorkOrderRequester", fields: [requesterId], references: [id], onDelete: Restrict)

  assigneeId String?
  assignee   User?   @relation("WorkOrderAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  dueAt       DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  notes       WorkOrderNote[]
  timeEntries WorkOrderTimeEntry[]

  @@index([siteId])
  @@index([assetId])
  @@index([status])
  @@index([priority])
  @@index([assigneeId])
  @@index([requesterId])
  @@index([dueAt])
}

model WorkOrderNote {
  id          String    @id @default(cuid())
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Restrict)
  body        String
  createdAt   DateTime  @default(now())

  @@index([workOrderId])
  @@index([authorId])
}

model WorkOrderTimeEntry {
  id          String    @id @default(cuid())
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  /// Hours worked (supports quarter-hour increments).
  hours       Float
  workDate    DateTime  @db.Date
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workOrderId])
  @@index([userId])
  @@index([workDate])
}

// ——— Access control & audit ———

model SiteAccess {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, siteId])
  @@index([userId])
  @@index([siteId])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String?
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

model AccessRequest {
  id               String              @id @default(cuid())
  requesterId      String
  requester        User                @relation("AccessRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  status           AccessRequestStatus @default(PENDING)
  requestedRole    UserRole
  requestedSiteIds Json?
  reason           String?
  reviewerId       String?
  reviewer         User?               @relation("AccessRequestReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  reviewNote       String?
  reviewedAt       DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([requesterId])
  @@index([status])
  @@index([createdAt])
}

model UserInvite {
  id          String    @id @default(cuid())
  email       String
  name        String?
  role        UserRole
  siteIds     Json?
  token       String    @unique
  invitedById String
  invitedBy   User      @relation("InviteSender", fields: [invitedById], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  acceptedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([email])
  @@index([expiresAt])
  @@index([invitedById])
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

// ——— Greentagging ———

model GreenTagAssignment {
  id          String         @id @default(cuid())
  title       String
  summary     String?
  /// Overall how-to for the whole greentagging effort (separate from per-case directions).
  instructions String?
  status      GreenTagStatus @default(OPEN)

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?   @relation("GreenTagAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cases          GreenTagCase[]
  checklistItems GreenTagChecklistItem[]

  @@index([assetId])
  @@index([status])
  @@index([assigneeId])
}

/// Checkable overall how-to steps for a greentagging assignment.
model GreenTagChecklistItem {
  id           String             @id @default(cuid())
  assignmentId String
  assignment   GreenTagAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  label        String
  sortOrder    Int                @default(0)
  completedAt  DateTime?
  completedById String?
  completedBy  User?              @relation("GreenTagChecklistCompleter", fields: [completedById], references: [id], onDelete: SetNull)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  photos       GreenTagChecklistPhoto[]

  @@index([assignmentId])
}

model GreenTagChecklistPhoto {
  id              String                @id @default(cuid())
  checklistItemId String
  checklistItem   GreenTagChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)
  /// Public URL path, e.g. /uploads/greentagging/<file>.
  url             String
  filename        String
  originalName    String
  mimeType        String
  sizeBytes       Int
  uploadedById    String?
  uploadedBy      User?                 @relation("GreenTagChecklistPhotoUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt       DateTime              @default(now())

  @@index([checklistItemId])
  @@index([uploadedById])
}

/// Process case within a greentagging effort — shown as subtabs on the assignment.
model GreenTagCase {
  id           String              @id @default(cuid())
  assignmentId String
  assignment   GreenTagAssignment  @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  title        String
  sortOrder    Int                 @default(0)
  /// Directions / how-to for completing this process case.
  directions   String?
  status       GreenTagStatus      @default(OPEN)
  completedAt  DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([assignmentId])
  @@index([status])
}

// ——— Inventory ———

model InventoryPart {
  id          String   @id @default(cuid())
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  partNumber  String
  location    String
  description String?
  quantity    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([assetId])
  @@index([partNumber])
}

// ——— Department SOPs ———

model SopDocument {
  id          String       @id @default(cuid())
  title       String
  department  String
  summary     String?
  content     String?
  documentUrl String?
  version     String       @default("1.0")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  versions    SopVersion[]

  @@index([department])
  @@index([title])
}

model SopVersion {
  id           String      @id @default(cuid())
  sopId        String
  sop          SopDocument @relation(fields: [sopId], references: [id], onDelete: Cascade)
  version      String
  title        String
  department   String
  summary      String?
  content      String?
  documentUrl  String?
  changeNote   String?
  publishedById String?
  publishedBy  User?       @relation("SopVersionPublisher", fields: [publishedById], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())

  @@index([sopId])
  @@index([createdAt])
}
