{
  "name": "maintenance-platform-server",
  "version": "1.0.0",
  "private": true,
  "description": "Express API for the maintenance platform using Prisma and PostgreSQL.",
  "main": "index.js",
  "scripts": {
    "build": "prisma generate",
    "postinstall": "prisma generate",
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "test:check": "node --check index.js && node --check src/app.js",
    "db:generate": "prisma generate",
    "db:migrate": "node ../scripts/refuse-destroy-data.js \"db:migrate (prisma migrate dev)\" && prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "node ../scripts/refuse-destroy-data.js \"db:push\" && prisma db push",
    "db:studio": "prisma studio"
  },
  "keywords": [
    "express",
    "maintenance",
    "prisma"
  ],
  "license": "ISC",
  "engines": {
    "node": ">=20.10.0"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "adm-zip": "^0.5.18",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "prisma": "^6.8.2",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.1"
  }
}
