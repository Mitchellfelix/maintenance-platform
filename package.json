{
  "name": "maintenance-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Combined Maintenance Platform app with React/Vite frontend and Express/Prisma backend.",
  "scripts": {
    "dev": "npm run dev --workspace client & npm run dev --workspace server",
    "build": "npm run build --workspace client && npm run build --workspace server",
    "start": "npm run start --workspace server",
    "test": "npm test --workspace server",
    "test:coverage": "npm run test:coverage --workspace server",
    "db:deploy": "npm run db:deploy --workspace server",
    "db:migrate": "npm run db:migrate --workspace server",
    "app:create": "bash scripts/create-desktop-app.sh",
    "app:install": "bash scripts/install-app.sh",
    "app:desktop": "bash scripts/run-desktop.sh",
    "app:launch": "bash scripts/run-desktop.sh",
    "app:stop": "bash scripts/stop-app.sh",
    "team:serve": "bash scripts/team-serve.sh",
    "team:connect": "bash scripts/team-connect.sh"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "devDependencies": {
    "electron": "^35.0.0"
  }
}
